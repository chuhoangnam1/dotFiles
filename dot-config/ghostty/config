theme = Gruvbox Dark
font-family = Monaco
font-size = 13
adjust-cell-width = 0
adjust-cell-height = 0

window-padding-x = 0
window-padding-y = 0
window-padding-balance = true
window-padding-color = background

cursor-style = block
cursor-style-blink = false
shell-integration-features = no-cursor

copy-on-select = false
confirm-close-surface = false
macos-shortcuts = deny
macos-titlebar-style = tabs

quick-terminal-size = 80%,80%
scrollback-limit = 9999999
window-save-state = always

working-directory = home

# Remap option-backspace to delete whole word
keybind = option+backspace=text:\x17
keybind = cmd+backslash=new_split:right
keybind = cmd+shift+backslash=new_split:down
# keybind = cmd+backslash=ignore
# keybind = cmd+shift+backslash=ignore

keybind = global:cmd+ctrl+'=toggle_quick_terminal

